# OpenAI API Configuration
# Get your API keys from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
# Dedicated key for mission plan generation (falls back to OPENAI_API_KEY if not set)
OPENAI_MISSION_API_KEY=your_mission_plan_openai_api_key_here

# Housing Finder — RentCast API (direct, not RapidAPI)
# 1. Go to https://www.rentcast.io/api
# 2. Sign up for a free account (includes free API credits)
# 3. Copy your API key from the dashboard
RENTCAST_API_KEY=your_rentcast_api_key_here

# Application Configuration (optional)
NODE_ENV=development
